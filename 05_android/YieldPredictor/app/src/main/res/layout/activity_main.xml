<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌾 Prédiction Rendement"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Sélection région -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Région"/>

        <Spinner
            android:id="@+id/spinnerRegion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- EVI max -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EVI maximum (0.0 - 1.0)"/>

        <EditText
            android:id="@+id/etEviMax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="ex: 0.55"
            android:layout_marginBottom="12dp"/>

        <!-- EVI moyen -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EVI moyen saison"/>

        <EditText
            android:id="@+id/etEviMean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="ex: 0.38"
            android:layout_marginBottom="12dp"/>

        <!-- Pluie saison -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pluviométrie saison (mm)"/>

        <EditText
            android:id="@+id/etPluie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="ex: 850"
            android:layout_marginBottom="24dp"/>

        <!-- Bouton prédire -->
        <Button
            android:id="@+id/btnPredire"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PRÉDIRE LE RENDEMENT"
            android:layout_marginBottom="24dp"/>

        <!-- Résultat -->
        <TextView
            android:id="@+id/tvResultat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Résultat : --"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"/>

    </LinearLayout>
</ScrollView>